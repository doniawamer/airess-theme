  "semanticTokenColors": {
    "class": "#FFD0E8",
    "interface": "#90D8F8",
    "enum": "#E0C8FF",
    "type": "#FFC8E8",
    "typeParameter": "#E8B8FF",
    "parameter": "#C8D8E8",
    "property": "#F8C0D8",
    "namespace": "#B8E8D0",
    "function": "#FFF0F8",
    "method": "#E8E0FF",
    "variable": "#E8C8D8",
    "string": "#FF98C8",
    "number": "#F0A0E0",
    "keyword": "#FFB0D8",
    "comment": {
      "foreground": "#A08098",
      "fontStyle": "italic"
    },
    "operator": "#C8B8E0"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#B8B0E8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#FF98C8"
      }
    },
    {
      "name": "Number / constant",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#E8A8F0"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFB0D8"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#C8B8E0"
      }
    },
    {
      "name": "Function call / definition",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#FFFAFC"
      }
    },
    {
      "name": "Class / type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#F8D8F0"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#D8D0E8"
      }
    },
    {
      "name": "Language variable (this, self)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#E8D0FF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tag / markup name",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#E8B8FF"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#D8C8FF"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#90D8F8"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#B8C8FF"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F8A8C8"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#F5D8E8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#D8C8FF",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#A8E8C8"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#F0B0C8"
      }
    }
  ]
}
