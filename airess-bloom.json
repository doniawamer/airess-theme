  "semanticTokenColors": {
    "class": "#C85088",
    "interface": "#2A98A8",
    "enum": "#E058A8",
    "type": "#C85898",
    "typeParameter": "#E04898",
    "parameter": "#505078",
    "property": "#C06090",
    "namespace": "#508878",
    "function": "#1E1838",
    "method": "#302868",
    "variable": "#5A3048",
    "string": "#D05088",
    "number": "#E070A8",
    "keyword": "#D83888",
    "comment": {
      "foreground": "#E8B0C8",
      "fontStyle": "italic"
    },
    "operator": "#D0A0C8"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#ECC8E0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#D05088"
      }
    },
    {
      "name": "Number / constant",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#E070A8"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D83888"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#D0A0C8"
      }
    },
    {
      "name": "Function call / definition",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#1E1838"
      }
    },
    {
      "name": "Class / type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#C85088"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#583048"
      }
    },
    {
      "name": "Language variable",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#C83898",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#C83898"
      }
    },
    {
      "name": "YAML mapping keys (block / flow)",
      "scope": [
        "meta.map.key.yaml",
        "meta.flow.map.key.yaml"
      ],
      "settings": {
        "foreground": "#552238"
      }
    },
    {
      "name": "YAML key tag token",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#552238"
      }
    },
    {
      "name": "YAML key + quoted / plain (compound scopes)",
      "scope": [
        "meta.map.key.yaml string.quoted.double.yaml",
        "meta.map.key.yaml string.quoted.single.yaml",
        "meta.map.key.yaml string.unquoted.plain.yaml",
        "meta.flow.map.key.yaml string.unquoted.plain.in.yaml"
      ],
      "settings": {
        "foreground": "#552238"
      }
    },
    {
      "name": "YAML map values (quoted)",
      "scope": [
        "meta.map.value.yaml string.quoted.double.yaml",
        "meta.map.value.yaml string.quoted.single.yaml"
      ],
      "settings": {
        "foreground": "#C42A68"
      }
    },
    {
      "name": "YAML map values (plain / block scalar)",
      "scope": [
        "meta.map.value.yaml string.unquoted.plain.yaml",
        "meta.map.value.yaml string.unquoted.block.yaml"
      ],
      "settings": {
        "foreground": "#B02858"
      }
    },
    {
      "name": "YAML flow mapping values",
      "scope": [
        "meta.flow.pair.value.yaml"
      ],
      "settings": {
        "foreground": "#B02858"
      }
    },
    {
      "name": "YAML key/value colon",
      "scope": [
        "punctuation.separator.map.value.yaml",
        "punctuation.separator.mapping.yaml"
      ],
      "settings": {
        "foreground": "#8A4862"
      }
    },
    {
      "name": "YAML block scalar markers",
      "scope": [
        "keyword.control.flow.block-scalar.literal.yaml",
        "keyword.control.flow.block-scalar.folded.yaml"
      ],
      "settings": {
        "foreground": "#6E3048"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C43880"
      }
    },
    {
      "name": "CSS property",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#2A98A8"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#8058B8"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#B84D78"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#B85090",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#C43880",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#58A878"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#B85A78"
      }
    }
  ]
}
